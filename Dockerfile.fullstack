# syntax=docker/dockerfile:1

FROM node:23-slim

RUN apt-get update && apt-get install -y \
  ca-certificates \
  curl \
  unzip \
  openssl \
  python3 \
  make \
  g++ \
  git \
  && rm -rf /var/lib/apt/lists/*

# Install Bun for Eliza runtime.
RUN curl -fsSL https://bun.sh/install | bash \
  && ln -sf /root/.bun/bin/bun /usr/local/bin/bun

ENV ELIZAOS_TELEMETRY_DISABLED=true
ENV DO_NOT_TRACK=1
ENV PORT=3000
ENV ELIZA_SERVER_PORT=3001
ENV ELIZA_AGENT_URL=http://127.0.0.1:3001
ENV DATABASE_URL=file:/app/data/polymarket.db

RUN npm install -g pnpm

WORKDIR /app

# Install agent dependencies.
COPY agent/package.json /app/agent/package.json
RUN cd /app/agent && pnpm install

# Install frontend dependencies.
COPY polymarket-intelligence-agent/package*.json /app/frontend/
RUN cd /app/frontend && npm ci

# Copy source code.
COPY agent /app/agent
COPY polymarket-intelligence-agent /app/frontend

# Build frontend artifacts.
RUN cd /app/frontend && npx prisma generate && npm run build

# Startup supervisor for both processes.
COPY docker/start-combined.sh /app/docker/start-combined.sh
RUN chmod +x /app/docker/start-combined.sh && mkdir -p /app/data

ENV NODE_ENV=production

EXPOSE 3000

CMD ["/app/docker/start-combined.sh"]
