# syntax=docker/dockerfile:1

FROM node:23-slim

RUN apt-get update && apt-get install -y \
  ca-certificates \
  curl \
  unzip \
  openssl \
  python3 \
  make \
  g++ \
  git \
  && rm -rf /var/lib/apt/lists/*

# Install Bun for Eliza runtime.
RUN curl -fsSL https://bun.sh/install | bash \
  && ln -sf /root/.bun/bin/bun /usr/local/bin/bun

ENV ELIZAOS_TELEMETRY_DISABLED=true
ENV DO_NOT_TRACK=1
ENV PORT=3000
ENV ELIZA_SERVER_PORT=3001
ENV ELIZA_AGENT_URL=http://127.0.0.1:3001
ENV DATABASE_URL=file:/app/data/polymarket.db

# Build-time injected runtime defaults (used when deployment only pulls image).
ARG OPENAI_BASE_URL=https://5i8frj7ann99bbw9gzpprvzj2esugg39hxbb4unypskq.node.k8s.prd.nos.ci/v1
ARG OPENAI_SMALL_MODEL=Qwen3.5-9B-FP8
ARG OPENAI_LARGE_MODEL=Qwen3.5-9B-FP8
ARG MODEL_NAME=Qwen3.5-9B-FP8
ARG OPENROUTER_FALLBACK_MODEL=anthropic/claude-3-haiku
ARG EMBED_DEMO_DB=true

ENV OPENAI_BASE_URL=${OPENAI_BASE_URL}
ENV OPENAI_SMALL_MODEL=${OPENAI_SMALL_MODEL}
ENV OPENAI_LARGE_MODEL=${OPENAI_LARGE_MODEL}
ENV MODEL_NAME=${MODEL_NAME}
ENV OPENROUTER_FALLBACK_MODEL=${OPENROUTER_FALLBACK_MODEL}

RUN npm install -g pnpm

WORKDIR /app

# Install agent dependencies.
COPY agent/package.json /app/agent/package.json
RUN cd /app/agent && pnpm install

# Install frontend dependencies.
COPY polymarket-intelligence-agent/package*.json /app/frontend/
RUN cd /app/frontend && npm ci

# Copy source code.
COPY agent /app/agent
COPY polymarket-intelligence-agent /app/frontend

# Build frontend artifacts.
RUN cd /app/frontend && npx prisma generate && npm run build

# Startup supervisor for both processes.
COPY docker/start-combined.sh /app/docker/start-combined.sh
COPY docker/llm-proxy.mjs /app/docker/llm-proxy.mjs
RUN chmod +x /app/docker/start-combined.sh && mkdir -p /app/data

# Optional demo snapshot: bake local SQLite into image for pull-only deployments.
RUN if [ "$EMBED_DEMO_DB" = "true" ] && [ -f /app/frontend/prisma/prisma/dev.db ]; then \
      cp /app/frontend/prisma/prisma/dev.db /app/data/polymarket.db; \
    fi

# Persist OpenRouter secret from BuildKit secret mount for pull-only runtimes.
RUN --mount=type=secret,id=openrouter_key \
  if [ -f /run/secrets/openrouter_key ]; then \
    cp /run/secrets/openrouter_key /app/.openrouter_key && chmod 600 /app/.openrouter_key; \
  fi

ENV NODE_ENV=production

EXPOSE 3000

CMD ["/app/docker/start-combined.sh"]
