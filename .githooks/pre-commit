#!/bin/sh
set -eu

# Scan staged additions for common secret patterns before commit.
staged_patch=$(git diff --cached --unified=0 --no-color -- .)

if printf "%s" "$staged_patch" | grep -E '^\+[^+].*sk-or-v1-[A-Za-z0-9]{20,}' >/dev/null; then
  echo "Blocked commit: detected OpenRouter key pattern in staged changes."
  echo "Move secrets to local .env files and remove them from tracked files."
  exit 1
fi

if printf "%s" "$staged_patch" | grep -E '^\+[^+].*(OPENROUTER_API_KEY|OPENAI_API_KEY)\s*[:=]\s*["'"'"']?[^"'"'"' ]{10,}' >/dev/null; then
  echo "Blocked commit: detected API key assignment in staged changes."
  echo "Use placeholders in tracked files and keep real values in ignored .env files."
  exit 1
fi

if printf "%s" "$staged_patch" | grep -E '^\+[^+].*ghp_[A-Za-z0-9]{20,}' >/dev/null; then
  echo "Blocked commit: detected GitHub token pattern in staged changes."
  exit 1
fi

exit 0
